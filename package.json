{
  "name": "klovr-artifact-share",
  "version": "0.1.0",
  "private": true,
  "description": "Klovr-owned HTML artifact sharing service with password and expiry support.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "share": "tsx src/cli/klovrShare.ts",
    "admin": "tsx src/cli/admin.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/storage": "^7.21.0",
    "argon2": "^0.43.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.9",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
